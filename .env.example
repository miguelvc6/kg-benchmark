MODEL_PROVIDER=openai
# Optional endpoint selector used by src/reasoning_floor.py.
# Supported values: ollama, azure, university, openai.
# MODEL_ENDPOINT=ollama

# Generic OpenAI-compatible configuration used by src/reasoning_floor.py.
# Set these to the provider you want for benchmark runs.
OPENAI_API_KEY=YOUR_API_KEY
OPENAI_MODEL=YOUR_MODEL_NAME
OPENAI_REASONING_EFFORT=low
# OPENAI_BASE_URL=https://your-compatible-endpoint/v1
OPENAI_INPUT_COST_PER_1M_TOKENS=2.50
OPENAI_OUTPUT_COST_PER_1M_TOKENS=10.00

# Local Ollama configuration.
# The smoke-test script uses these directly when approach=ollama.
# Set MODEL_ENDPOINT=ollama when you want src/reasoning_floor.py to use Ollama.
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/api
# OLLAMA_API_KEY=your_api_key
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CONTEXT_LENGTH=4096
OLLAMA_INPUT_COST_PER_1M_TOKENS=0.00
OLLAMA_OUTPUT_COST_PER_1M_TOKENS=0.00
REASONING_FLOOR_PARALLEL_WORKERS=2

# Azure AI OpenAI-compatible endpoint.
# Tested with: kg-test-llm-endpoint azure
AZURE_OPENAI_ENDPOINT=https://mvazquez-it-184686-ki.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-nano
AZURE_OPENAI_API_KEY=your-api-key
# AZURE_OPENAI_INPUT_COST_PER_1M_TOKENS=0.00
# AZURE_OPENAI_OUTPUT_COST_PER_1M_TOKENS=0.00

# University OpenAI-compatible Responses endpoint.
# Tested with: kg-test-llm-endpoint university
UNIVERSITY_OPENAI_BASE_URL=https://demosite.ml.jku.at/v1
UNIVERSITY_OPENAI_MODEL=Qwen/Qwen3-4B
UNIVERSITY_OPENAI_API_KEY=add-api-key
UNIVERSITY_OPENAI_TIMEOUT_SECONDS=240
UNIVERSITY_OPENAI_MAX_OUTPUT_TOKENS=1024
UNIVERSITY_OPENAI_MAX_RETRIES=4
UNIVERSITY_OPENAI_RETRY_BASE_SECONDS=2
UNIVERSITY_OPENAI_RETRY_MAX_SECONDS=20
# UNIVERSITY_OPENAI_INPUT_COST_PER_1M_TOKENS=0.00
# UNIVERSITY_OPENAI_OUTPUT_COST_PER_1M_TOKENS=0.00
